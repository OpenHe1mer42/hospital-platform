<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="carely.controller.pages.DoctorsController"
           maxWidth="Infinity"
           maxHeight="Infinity"
           styleClass="doctors-page-root">
    <VBox spacing="20" maxWidth="Infinity" maxHeight="Infinity" styleClass="page-placeholder doctors-page">
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="doctors-header">
            <Label text="Doctors" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="openCreateDoctorButton"
                    text="Create Doctor"
                    onAction="#onOpenCreateDoctorModal"
                    styleClass="primary-button"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="profile-panel doctors-filter-panel">
            <TextField fx:id="searchFilterField"
                       promptText="Search name or email"
                       onAction="#onFilterDoctors"
                       minWidth="320"
                       prefWidth="480"
                       HBox.hgrow="ALWAYS"
                       styleClass="profile-input"/>
            <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="filter-actions">
                <ComboBox fx:id="statusFilterComboBox"
                          minWidth="150"
                          prefWidth="150"
                          styleClass="profile-input"/>
                <Button text="Filter" onAction="#onFilterDoctors" styleClass="secondary-button"/>
                <Button text="Clear" onAction="#onClearFilters" styleClass="secondary-button"/>
            </HBox>
        </HBox>

        <Label fx:id="listMessageLabel" wrapText="true" minHeight="20" styleClass="message-label"/>

        <VBox spacing="0" styleClass="profile-panel doctors-table-panel">
            <TableView fx:id="doctorsTable" styleClass="doctors-table">
                <columns>
                    <TableColumn fx:id="fullNameColumn" text="Full name" prefWidth="260"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="360"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="130"/>
                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="130" sortable="false" reorderable="false"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>

    <VBox fx:id="createDoctorDialog"
          alignment="CENTER_LEFT"
          spacing="16"
          prefWidth="540"
          maxWidth="540"
          visible="false"
          managed="false"
          styleClass="doctor-modal-card">
        <VBox spacing="5">
            <Label fx:id="doctorDialogTitleLabel" text="Create doctor account" styleClass="profile-section-title"/>
            <Label fx:id="doctorDialogSubtitleLabel"
                   text="Doctor accounts can sign in after an administrator creates them."
                   wrapText="true"
                   styleClass="profile-section-subtitle"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Full name" styleClass="profile-field-label"/>
            <TextField fx:id="fullNameField" promptText="Full name" styleClass="profile-input"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Email" styleClass="profile-field-label"/>
            <TextField fx:id="emailField" promptText="Email address" styleClass="profile-input"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Password" styleClass="profile-field-label"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="profile-input"/>
        </VBox>

        <VBox spacing="8">
            <Label text="Confirm password" styleClass="profile-field-label"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm password"
                           onAction="#onCreateDoctor"
                           styleClass="profile-input"/>
        </VBox>

        <CheckBox fx:id="activeCheckBox" text="Active" selected="true"/>
        <Label fx:id="createMessageLabel" wrapText="true" minHeight="20" styleClass="message-label"/>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="modal-actions">
            <Button text="Cancel" onAction="#onCloseCreateDoctorModal" styleClass="secondary-button"/>
            <Button fx:id="createDoctorButton"
                    text="Create Doctor"
                    onAction="#onCreateDoctor"
                    defaultButton="true"
                    styleClass="primary-button"/>
        </HBox>
    </VBox>
</StackPane>
